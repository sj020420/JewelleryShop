# Server
PORT=5000
NODE_ENV=development
CLIENT_URL=http://localhost:5173

# PostgreSQL (Neon) — get this from Neon Console → Project → Connection Details
# Use the pooled connection string (contains "-pooler" in the host) for Render.
DATABASE_URL=postgresql://user:password@ep-xxxx-pooler.region.aws.neon.tech/dbname?sslmode=require

# JWT
JWT_SECRET=change_this_to_a_long_random_secret
JWT_EXPIRES_IN=7d

# WhatsApp / Contact
WHATSAPP_NUMBER=919423033383

# File Uploads
MAX_FILE_SIZE_MB=5
